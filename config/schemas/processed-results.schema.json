{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/schemas/processed-results.schema.json",
  "title": "Processed Benchmark Results",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "benchmark_group_id",
    "profile_name",
    "php_profile",
    "aggregation",
    "dimensions",
    "summary"
  ],
  "properties": {
    "benchmark_group_id": {
      "type": "string"
    },
    "profile_name": {
      "type": "string"
    },
    "php_profile": {
      "type": "string"
    },
    "aggregation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "repetitions",
        "primary_metric",
        "dispersion_metric"
      ],
      "properties": {
        "repetitions": {
          "type": "integer",
          "minimum": 1
        },
        "primary_metric": {
          "type": "string",
          "enum": [
            "median"
          ]
        },
        "dispersion_metric": {
          "type": "string",
          "enum": [
            "iqr",
            "stddev"
          ]
        }
      }
    },
    "dimensions": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "framework",
        "framework_version",
        "php_version",
        "runtime_family",
        "runtime",
        "runtime_config",
        "scenario",
        "code_form"
      ],
      "properties": {
        "framework": {
          "type": "string"
        },
        "framework_version": {
          "type": "string"
        },
        "php_version": {
          "type": "string"
        },
        "runtime_family": {
          "type": "string"
        },
        "runtime": {
          "type": "string"
        },
        "runtime_config": {
          "type": "string"
        },
        "scenario": {
          "type": "string"
        },
        "code_form": {
          "type": "string"
        },
        "cache_state": {
          "type": "string"
        }
      }
    },
    "summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "requests_per_second_median",
        "latency_p95_ms_median",
        "error_count_total"
      ],
      "properties": {
        "requests_per_second_median": {
          "type": "number"
        },
        "requests_per_second_iqr": {
          "type": [
            "number",
            "null"
          ]
        },
        "latency_p50_ms_median": {
          "type": [
            "number",
            "null"
          ]
        },
        "latency_p95_ms_median": {
          "type": [
            "number",
            "null"
          ]
        },
        "latency_p99_ms_median": {
          "type": [
            "number",
            "null"
          ]
        },
        "error_count_total": {
          "type": "integer",
          "minimum": 0
        },
        "non_2xx_count_total": {
          "type": "integer",
          "minimum": 0
        },
        "delta_vs_plain_percent": {
          "type": [
            "number",
            "null"
          ]
        },
        "delta_vs_native_percent": {
          "type": [
            "number",
            "null"
          ]
        }
      }
    }
  }
}
